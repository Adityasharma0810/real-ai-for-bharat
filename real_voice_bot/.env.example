# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# Sarvam AI — for STT (speech-to-text) and TTS (text-to-speech)
# Get your key at: https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Groq — for the LLM (Llama 3.3 70B)
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# LiveKit Cloud — for real-time voice rooms
# Get these from your LiveKit Cloud project at: https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# CORS allowlist for browser clients (comma-separated). Leave empty to allow all.
# Example: ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://admin.example.com
ALLOWED_ORIGINS=

# Supabase — for syncing interview results to the dashboard
# Get these from your Supabase project settings → API
# Use the SERVICE ROLE key (not anon key) so the backend can bypass RLS
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
